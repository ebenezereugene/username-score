{
  "name": "username-score",
  "version": "1.0.0",
  "description": "An open-source, deterministic username scoring engine for TypeScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsx --watch packages/src/index.ts",
    "build:js": "tsup packages/src/index.ts --format esm,cjs --out-dir dist --clean",
    "build:types": "tsc --project tsconfig.build.json",
    "build": "npm run build:js && npm run build:types",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebenezereugene/username-score.git"
  },
  "keywords": [
    "username",
    "scoring",
    "brandability",
    "typescript",
    "nlp"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ebenezereugene/username-score/issues"
  },
  "homepage": "https://github.com/ebenezereugene/username-score#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
